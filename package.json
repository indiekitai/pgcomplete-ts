{
  "name": "@indiekitai/pgcomplete",
  "version": "0.1.0",
  "description": "PostgreSQL auto-completion engine ported from pgcli's pgcompleter.py",
  "type": "module",
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "bin": {
    "pgcomplete": "dist/cli.js"
  },
  "scripts": {
    "build": "tsc",
    "test": "vitest run",
    "start": "node dist/cli.js",
    "mcp": "node dist/mcp.js"
  },
  "keywords": ["postgresql", "autocomplete", "sql", "mcp"],
  "license": "MIT",
  "dependencies": {
    "pg": "^8.13.0",
    "node-sql-parser": "^5.3.6",
    "@modelcontextprotocol/sdk": "^1.12.1"
  },
  "devDependencies": {
    "@types/node": "^22.0.0",
    "@types/pg": "^8.11.0",
    "typescript": "^5.7.0",
    "vitest": "^3.0.0"
  },
  "files": ["dist", "pgliterals.json"]
}
